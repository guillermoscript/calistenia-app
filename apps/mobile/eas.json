{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_PB_URL": "https://gym.guille.tech",
        "EXPO_PUBLIC_AI_API_URL": "https://gym-server.guille.tech"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_PB_URL": "https://gym.guille.tech",
        "EXPO_PUBLIC_AI_API_URL": "https://gym-server.guille.tech"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
