# ─── Frontend (build-time, baked into JS bundle) ────────────────────────────
# Leave empty in prod if frontend is served from PocketBase (uses window.origin)
VITE_POCKETBASE_URL=http://127.0.0.1:8090
# Absolute URL of the AI API. Empty in dev (Vite proxy handles it).
VITE_AI_API_URL=

# ─── AI API: Provider Keys (at least one required) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# ─── AI API: Model Configuration (optional) ────────────────────────────────
# Preferred provider when multiple keys are set: 'anthropic' | 'google' | 'openai'
DEFAULT_AI_PROVIDER=
# Override specific model IDs per tier (e.g. 'claude-haiku-4-5', 'gpt-4o')
DEFAULT_MODEL_FREE=
DEFAULT_MODEL_PRO=

# ─── AI API: Rate Limiting (optional) ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# ─── PocketBase Internal (used by AI API container) ────────────────────────
POCKETBASE_URL=http://app:8090

# ─── MCP public origin (used by AI API container) ──────────────────────────
# Public URL of this server. Required for OAuth 2.1 discovery so remote MCP
# clients (e.g. Claude Desktop Connectors) resolve issuer/authorize/token.
# Set to your domain in prod (Dokploy env vars). Defaults to localhost locally.
SERVER_URL=http://localhost:3001

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Android push via direct FCM v1 (server-side). See mcp-server/.env.example.
# FCM_SERVICE_ACCOUNT=  (inline service-account JSON)  OR
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json

# ─── Internal API Key (PB hooks → AI API server-to-server auth) ─────────────
INTERNAL_API_KEY=

# ─── Sentry (frontend) ──────────────────────────────────────────────────────
VITE_SENTRY_DSN=
# Origin for Sentry trace propagation (defaults to https://gym-server.guille.tech)
VITE_API_ORIGIN=

# ─── PocketBase Seed Script ─────────────────────────────────────────────────
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=your-password

# ─── OpenPanel (self-hosted analytics) ──────────────────────────────────────
# CLIENT_ID is public (baked into frontend bundle). SECRET is server-side only.
VITE_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=

# ─── USDA FoodData Central (nutrition lookups) ──────────────────────────────
USDA_API_KEY=

# ─── Langfuse (LLM observability, used by mcp-server) ───────────────────────
# NOTE: env var is LANGFUSE_BASEURL (no underscore between BASE and URL)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
