# ─── Frontend ────────────────────────────────────────────────────────────────
# Dejar vacío en producción si el frontend se sirve desde PocketBase (usa window.origin)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# URL del servicio AI de nutrición. Vacío en dev (usa proxy de Vite). En prod: URL absoluta.
VITE_AI_API_URL=

# ─── AI API Keys (solo para el servicio Express, NO van en el frontend) ─────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# ─── PocketBase Seed Script ─────────────────────────────────────────────────
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=your-password
