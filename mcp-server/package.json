{
  "name": "calistenia-server",
  "version": "1.0.0",
  "description": "Unified server for Calistenia App — REST API + MCP tools for Claude",
  "type": "module",
  "scripts": {
    "build": "mcp-use build --path . --entry src/server.ts --widgets-dir resources",
    "build:server": "rm -rf build && tsc",
    "start": "node build/server.js",
    "dev": "mcp-use dev --path . --entry src/server.ts --widgets-dir resources --no-open",
    "dev:simple": "tsx src/server.ts",
    "seed": "node build/seed.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@langfuse/otel": "^5.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "ai": "^6.0.206",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^3.15.0",
    "langfuse": "^3.38.20",
    "mcp-use": "^1.32.0",
    "pocketbase": "^0.27.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
