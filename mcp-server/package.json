{
  "name": "calistenia-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Calistenia App — manage training, nutrition, and progress data via Claude",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
