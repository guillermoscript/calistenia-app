# PocketBase URL (where your calistenia app's PocketBase is running)
POCKETBASE_URL=http://127.0.0.1:8090

# MCP HTTP Server settings
MCP_SERVER_PORT=3002
MCP_SERVER_HOST=127.0.0.1

# ── Public URL (required for OAuth 2.1 / remote MCP clients) ─────────────────
# Set this to your deployed server's public URL so OAuth metadata resolves correctly.
# For local dev, leave unset (defaults to http://localhost:PORT).
# SERVER_URL=https://calistenia.example.com

# ── stdio mode only ──────────────────────────────────────────────────────────
# Provide a valid PocketBase JWT for direct stdio usage (e.g. Claude Desktop local)
# Get it from browser devtools: localStorage.getItem("pb_auth") -> token field
# PB_TOKEN=your_pocketbase_jwt_token_here

# ── AI Providers ────────────────────────────────────────────────────────────
# At least one is required
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=

# ── Langfuse (AI cost & usage tracking) ───────────────────────────────────
# Sign up at https://cloud.langfuse.com or self-host
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Background job processing ──────────────────────────────────────────────
# PocketBase superuser credentials (required for async AI jobs)
# PB_SUPERUSER_EMAIL=
# PB_SUPERUSER_PASSWORD=

# ─── Android Push (direct FCM v1) ────────────────────────────────────────────
# Android notifications go straight to FCM (not via Expo). Provide a Firebase
# service-account key (Firebase console → Project settings → Service accounts →
# Generate new private key). Use ONE of:
#   FCM_SERVICE_ACCOUNT = inline JSON string of the service-account key
#   GOOGLE_APPLICATION_CREDENTIALS = absolute path to the service-account .json
# project_id is read from the key; override with FCM_PROJECT_ID if needed.
# FCM_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/calistenia-30ab8-xxxx.json
# FCM_PROJECT_ID=calistenia-30ab8
