# Expo / React Native + pnpm monorepo:
# Metro and Babel resolve presets/plugins from the package root upward, but
# pnpm's strict layout hides transitive deps (e.g. @babel/plugin-transform-react-jsx
# pulled in by babel-preset-expo). Hoist the native toolchain to the root
# node_modules so the Android release bundle (createBundleReleaseJsAndAssets) resolves them.
public-hoist-pattern[]=*@babel/*
public-hoist-pattern[]=*babel-preset*
public-hoist-pattern[]=*babel-plugin*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=react-native
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=*expo*
